{
  "name": "iom-website",
  "private": true,
  "version": "1.0.0",
  "description": "IOM — Interactive Object Media agency website",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run build:ravens && npm run build:panorama-360 && node scripts/generate-sitemap.mjs && tsc -b && vite build",
    "seo:sitemap": "node scripts/generate-sitemap.mjs",
    "build:panorama-360": "node scripts/build-panorama-360.mjs",
    "build:streets-gl": "node scripts/build-streets-gl.mjs",
    "build:ravens": "node scripts/sync-raven-assets.mjs && node scripts/build-mobile-raven.mjs",
    "build:mobile-raven": "node scripts/build-mobile-raven.mjs",
    "build:favicons": "node scripts/build-favicons.mjs",
    "preview": "vite preview",
    "predeploy:check": "node scripts/pre-deploy-check.mjs",
    "deploy:prod": "node scripts/pre-deploy-check.mjs && npm run build && git push origin master && npx vercel --prod --yes",
    "deploy": "npm run deploy:prod"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "three": "^0.181.0"
  },
  "devDependencies": {
    "@gltf-transform/core": "^4.4.1",
    "@gltf-transform/functions": "^4.4.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.181.0",
    "@vitejs/plugin-react": "^4.3.4",
    "playwright": "^1.61.1",
    "sharp": "^0.35.3",
    "typescript": "~5.7.2",
    "vite": "^6.0.0"
  }
}
