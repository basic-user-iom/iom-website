# Web3Forms access key — register at https://web3forms.com with iom-production@proton.me
# Copy this file to .env for local dev, and add the key to Vercel:
# Project Settings → Environment Variables → VITE_WEB3FORMS_ACCESS_KEY
VITE_WEB3FORMS_ACCESS_KEY=

# ── Client Login CRM (Supabase) ─────────────────────────────────────────────
# 1. Create a project at https://supabase.com
# 2. Run supabase/schema.sql in the SQL Editor
# 3. Authentication → Users → Add user (email + password) for staff login
# 4. Project Settings → API Keys → copy Project URL and Publishable key
#    (sb_publishable_…). Env var name stays VITE_SUPABASE_ANON_KEY for
#    compatibility; @supabase/supabase-js accepts publishable keys.
#    Fallback: Legacy anon JWT from the "Legacy anon, service_role API keys" tab.
# 5. Also set these in Vercel → Environment Variables, then redeploy
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Used only when Supabase vars are empty (browser-local demo mode)
# Default password if unset: iom-local
VITE_CRM_LOCAL_PASSWORD=iom-local

# ── Artist Globe demo (/artist-globe) ───────────────────────────────────────
# Admin moderation password (browser unlock + api/artist-globe-admin.js)
# Default if unset: iom-globe-admin
VITE_ARTIST_GLOBE_ADMIN_PASSWORD=iom-globe-admin
# Optional server-only override (Vercel). Prefer setting SUPABASE_SERVICE_ROLE_KEY
# for approve/reject against live Supabase; otherwise the UI uses localStorage.
# ARTIST_GLOBE_ADMIN_PASSWORD=
# SUPABASE_SERVICE_ROLE_KEY=


# ── Proton SMTP (CRM outreach send) ─────────────────────────────────────────
# Host/port shared by all identities. Each From address needs its own SMTP token.
PROTON_SMTP_HOST=smtp.protonmail.ch
PROTON_SMTP_PORT=587

# contact@ — website default + general CRM From
PROTON_SMTP_USER=contact@iobjectm.com
PROTON_SMTP_FROM=IOM <contact@iobjectm.com>
PROTON_SMTP_PASS=

# visual@ — photography / film / visual arts
PROTON_SMTP_VISUAL_USER=visual@iobjectm.com
PROTON_SMTP_VISUAL_FROM=IOM Visual <visual@iobjectm.com>
PROTON_SMTP_VISUAL_PASS=

# projects@ — project inquiries / collaborations
PROTON_SMTP_PROJECTS_USER=projects@iobjectm.com
PROTON_SMTP_PROJECTS_FROM=IOM Projects <projects@iobjectm.com>
PROTON_SMTP_PROJECTS_PASS=

# ── CRM scheduled outreach (/api/crm-scheduled-send) ────────────────────────
# Vercel Hobby runs this once daily (08:00 UTC) via vercel.json crons.
# For ~5 min precision, also ping the same URL from an external cron with:
#   Authorization: Bearer <CRM_CRON_SECRET>
# Same value as Vercel CRON_SECRET (optional alias). Required for auto-send.
# CRM_CRON_SECRET=
# SUPABASE_SERVICE_ROLE_KEY=   # server-only; used by cron to patch leads

# ── CRM inbound email (Resend Receiving → /api/crm-resend-inbound) ──────────
# See docs/crm-email-inbound-setup.md
# CRM_INBOUND_EMAIL_SECRET=
# RESEND_API_KEY=
# RESEND_WEBHOOK_SECRET=

# ── Screen Recorder AI voice morph (ElevenLabs) ─────────────────────────────
# Server-only (no VITE_ prefix). Set on Vercel → Environment Variables, then redeploy.
# Get key: https://elevenlabs.io/app/settings/api-keys
# Optional voice: Voices → copy Voice ID (used as default in the recorder dropdown).
# You do not need to list every voice — the CRM loads all voices from your account.
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=

# ── CRM recordings storage (Cloudflare R2 — 10 GB free) ─────────────────────
# See docs/r2-recordings-setup.md. Without these, uploads use Supabase Storage
# (Free plan hard-caps ~50 MB per file).
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=crm-screen-recordings

