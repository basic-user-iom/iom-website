# Web3Forms access key — register at https://web3forms.com with iom-production@proton.me
# Copy this file to .env for local dev, and add the key to Vercel:
# Project Settings → Environment Variables → VITE_WEB3FORMS_ACCESS_KEY
VITE_WEB3FORMS_ACCESS_KEY=

# ── Client Login CRM (Supabase) ─────────────────────────────────────────────
# 1. Create a project at https://supabase.com
# 2. Run supabase/schema.sql in the SQL Editor
# 3. Authentication → Users → Add user (email + password) for staff login
# 4. Project Settings → API Keys → copy Project URL and Publishable key
#    (sb_publishable_…). Env var name stays VITE_SUPABASE_ANON_KEY for
#    compatibility; @supabase/supabase-js accepts publishable keys.
#    Fallback: Legacy anon JWT from the "Legacy anon, service_role API keys" tab.
# 5. Also set these in Vercel → Environment Variables, then redeploy
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Used only when Supabase vars are empty (browser-local demo mode)
# Default password if unset: iom-local
VITE_CRM_LOCAL_PASSWORD=iom-local

# ── Proton SMTP (CRM outreach send) ─────────────────────────────────────────
# Host/port shared by all identities. Each From address needs its own SMTP token.
PROTON_SMTP_HOST=smtp.protonmail.ch
PROTON_SMTP_PORT=587

# contact@ — website default + general CRM From
PROTON_SMTP_USER=contact@iobjectm.com
PROTON_SMTP_FROM=IOM <contact@iobjectm.com>
PROTON_SMTP_PASS=

# visual@ — photography / film / visual arts
PROTON_SMTP_VISUAL_USER=visual@iobjectm.com
PROTON_SMTP_VISUAL_FROM=IOM Visual <visual@iobjectm.com>
PROTON_SMTP_VISUAL_PASS=

# projects@ — project inquiries / collaborations
PROTON_SMTP_PROJECTS_USER=projects@iobjectm.com
PROTON_SMTP_PROJECTS_FROM=IOM Projects <projects@iobjectm.com>
PROTON_SMTP_PROJECTS_PASS=
